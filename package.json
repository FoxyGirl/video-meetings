{
  "name": "video-meetings",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "npm run start:dev --workspace=api",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace=web",
    "build:api": "npm run build --workspace=api",
    "start": "concurrently -n web,api -c blue,green \"npm run start --workspace=web\" \"npm run start:prod --workspace=api\"",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.9.5",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "apps/web/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix --config apps/web/eslint.config.mjs"
    ],
    "apps/api/**/*.ts": [
      "eslint --fix --config apps/api/eslint.config.mjs"
    ],
    "**/*.{js,jsx,ts,tsx,json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  }
}
